PORT=8787
KELPCLAW_PUBLIC_BASE_URL=http://127.0.0.1:8787
KELPCLAW_ADMIN_TOKEN=change-me-admin-token
KELPCLAW_WORKFLOW_STORE=sqlite
KELPCLAW_WORKFLOW_DB=.kelpclaw/workflow.sqlite
KELPCLAW_SECRET_DB=.kelpclaw/workflow.sqlite
KELPCLAW_SECRET_MASTER_KEY=change-me-32-byte-minimum-master-key
KELPCLAW_ARTIFACT_STORE=.kelpclaw/artifacts
KELPCLAW_PREFLIGHT=1

# Default mock/offline mode starts without provider credentials. Switch to one of the live provider
# blocks below when you want real planner, agentic research, or codegen role calls.
KELPCLAW_PLANNER_MODE=deterministic
KELPCLAW_PLANNER_PROVIDER=anthropic
KELPCLAW_PLANNER_MODEL=
KELPCLAW_AGENTIC_PROVIDER=
KELPCLAW_AGENTIC_MODEL=
KELPCLAW_CODEGEN_PROVIDER=
KELPCLAW_CODEGEN_MODEL=
KELPCLAW_OPENAI_PLANNER_MODEL=
KELPCLAW_OPENAI_CODEGEN_MODEL=
KELPCLAW_OPENAI_AGENTIC_MODEL=
KELPCLAW_OPENAI_FIXER_MODEL=
KELPCLAW_OPENAI_EVALUATOR_MODEL=
KELPCLAW_OPENWEIGHT_BASE_URL=
KELPCLAW_OPENWEIGHT_API_KEY=
KELPCLAW_OPENWEIGHT_MODEL=
KELPCLAW_OPENWEIGHT_PLANNER_MODEL=
KELPCLAW_OPENWEIGHT_CODEGEN_MODEL=
KELPCLAW_OPENWEIGHT_AGENTIC_MODEL=
KELPCLAW_OPENWEIGHT_FIXER_MODEL=
KELPCLAW_OPENWEIGHT_EVALUATOR_MODEL=
KELPCLAW_ANTHROPIC_AGENTIC_MODEL=
KELPCLAW_ANTHROPIC_CODEGEN_MODEL=
KELPCLAW_ANTHROPIC_FIXER_MODEL=
KELPCLAW_ANTHROPIC_EVALUATOR_MODEL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

NANOCLAW_RUNNER=production
NANOCLAW_DOCKER_BIN=docker
NANOCLAW_HOST_WORKSPACE=/workspace

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_REVOKE_URL=https://oauth2.googleapis.com/revoke

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=kelpclaw@localhost

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0
TELEGRAM_DEFAULT_CHAT_ID=

# OpenAI-only live mode:
# KELPCLAW_PLANNER_MODE=live
# KELPCLAW_PLANNER_PROVIDER=openai
# KELPCLAW_AGENTIC_PROVIDER=openai
# KELPCLAW_CODEGEN_PROVIDER=openai
# OPENAI_API_KEY=sk-...
#
# Anthropic-only live mode:
# KELPCLAW_PLANNER_MODE=live
# KELPCLAW_PLANNER_PROVIDER=anthropic
# KELPCLAW_AGENTIC_PROVIDER=anthropic
# KELPCLAW_CODEGEN_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
#
# Open-weight OpenAI-compatible live mode:
# KELPCLAW_PLANNER_MODE=live
# KELPCLAW_PLANNER_PROVIDER=openweight
# KELPCLAW_AGENTIC_PROVIDER=openweight
# KELPCLAW_CODEGEN_PROVIDER=openweight
# KELPCLAW_OPENWEIGHT_BASE_URL=http://127.0.0.1:11434/v1
# KELPCLAW_OPENWEIGHT_API_KEY=local
# KELPCLAW_OPENWEIGHT_MODEL=qwen2.5-coder
#
# Test/dev only:
# KELPCLAW_PLANNER_MODE=deterministic
# NANOCLAW_RUNNER=mock
# KELPCLAW_SECRET_STORE=memory

OPENCLAW_API_TARGET=http://api:8787
VITE_OPENCLAW_ADMIN_TOKEN=change-me-admin-token
